{
  "name": "draggavue",
  "version": "0.0.0",
  "description": "Lightweight, type-safe, accessible drag & drop primitives for Vue.js",
  "keywords": [
    "accessibility",
    "composable",
    "drag",
    "draggable",
    "drop",
    "headless",
    "sortable",
    "vue"
  ],
  "license": "MIT",
  "author": "ubugeeei <ubuge1122@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ubugeeei-prod/draggavue.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/browser-playwright": "^4.1.10",
    "@vizejs/vite-plugin": "^0.291.0",
    "esbuild": "^0.28.1",
    "playwright": "^1.61.1",
    "typescript": "^7.0.2",
    "vite-plus": "^0.2.5",
    "vitest": "^4.1.10",
    "vize": "^0.291.0",
    "vue": "^3.5.40"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "packageManager": "pnpm@11.14.0"
}
